# DeepFleet web app
# Copy to .env and fill in values.

# Database (MySQL / TiDB)
DATABASE_URL=mysql://user:pass@localhost:3306/deepfleet

# Session cookies
JWT_SECRET=change-me-to-a-long-random-string

# Manus OAuth (or compatible OAuth server)
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=

# LLM gateway for built-in run engine
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Optional: self-hosted deepagents Python worker
WORKER_URL=
WORKER_TOKEN=

# Server port (default 3000)
PORT=3000
